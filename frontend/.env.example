# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional default issuer used in forms/snippets
NEXT_PUBLIC_USDC_ISSUER=

# Stellar Horizon Server URL
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar Network Passphrase (testnet or public)
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# WalletConnect v2 — project ID from https://cloud.reown.com
# Required for WalletConnect wallet support; leave empty to disable
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-here

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
NEXT_PUBLIC_SENTRY_RELEASE=stellar-payment-frontend@1.0.0
