PORT=4000

# Sentry DSN for error tracking and performance monitoring (optional)
# Obtain from: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=
PAYMENT_LINK_BASE=http://localhost:3000

# Supabase (service role key is required for server-side inserts)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# pg connection pool — use the Transaction Pooler URI from Supabase dashboard:
# Project Settings → Database → Connection string → Transaction (port 6543) → URI
# Example: postgresql://postgres.xxxx:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_transaction_pooler_uri

# Redis connection used for distributed rate limiting across app instances
# Example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Stellar config
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=

# SEP-0010 Web Authentication
# Generate with: node -e "console.log(require('stellar-sdk').Keypair.random().secret())"
SEP10_SERVER_SIGNING_KEY=your_secret_key_here
HOME_DOMAIN=localhost
JWT_SECRET=your_jwt_secret_here

# SEP-10 rate limiting (optional overrides)
SEP10_CHALLENGE_RATE_LIMIT_WINDOW_MS=60000
SEP10_CHALLENGE_RATE_LIMIT_MAX=20
SEP10_VERIFY_RATE_LIMIT_WINDOW_MS=60000
SEP10_VERIFY_RATE_LIMIT_MAX=10

# SEP-12 KYC rate limiting (optional overrides)
SEP12_RATE_LIMIT_WINDOW_MS=900000
SEP12_RATE_LIMIT_MAX=50
SEP12_RATE_LIMIT_WRITE_WINDOW_MS=3600000
SEP12_RATE_LIMIT_WRITE_MAX=10

# Optional asset issuers
USDC_ISSUER=your_usdc_issuer

# x402 pay-per-request config
# Charge applied to POST /api/create-payment and POST /api/sessions
# Note: charged endpoints still require merchant API key auth.
X402_PROVIDER_PUBLIC_KEY=your_stellar_public_key
X402_JWT_SECRET=replace_with_random_secret
X402_TOKEN_EXPIRY_SECONDS=60
X402_CREATE_PAYMENT_AMOUNT=0.01
# Optional: when false, x402 is opt-in per request via header/query.
# true  => every create-payment/sessions call is challenged when token missing
# false => only requests with x-pluto-pricing-mode: x402 (or ?pricing_mode=x402) are challenged
X402_ENFORCE_DEFAULT=false

# Webhook signing – shared secret used to produce Stellar-Signature: sha256=<hmac>
# Generate a strong random value, e.g.: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret

# Webhook secret rotation grace window in hours (old secret remains valid until expiry)
# Default: 24
WEBHOOK_SECRET_ROTATION_GRACE_HOURS=24

# CORS configuration – comma-separated list of allowed origins
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Create-payment endpoint rate limit configuration
# Defaults: 50 requests per 60 seconds per API key
CREATE_PAYMENT_RATE_LIMIT_MAX=50
CREATE_PAYMENT_RATE_LIMIT_WINDOW_MS=60000


# Resend API key for sending payment receipt emails to merchants
RESEND_API_KEY=your_resend_api_key

# Resend API key for payment receipt emails
# Obtain from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# Sender address for receipt emails (must be a verified domain in Resend)
# Defaults to: receipts@notifications.dripsnetwork.com
RECEIPT_FROM_EMAIL=receipts@yourdomain.com
